#====================#
# Talmed's i3 Config #
#====================#

#===========#
# Variables #
#===========#

set $mod Mod4

set $left h
set $down j
set $up k
set $right l

set $term kitty
set $browser firefox

#==========#
# Settings #
#==========#

default_orientation horizontal

# Startup applications
exec $term
exec spotify
exec pavucontrol
exec $browser

# Position Apps to certain workspaces
exec i3-wait class kitty 'move workspace 1'
exec i3-wait instance spotify 'move workspace 2'
exec i3-wait instance spotify 'move left'
exec i3-wait class pavucontrol 'move workspace 2'
exec i3-wait class firefox 'move workspace 3'

# Startup Services
exec xhost +
exec --no-startup-id dex --autostart --environment i3
exec --no-startup-id nm-applet
exec --no-startup-id spotify-notify-daemon

#========================#
# Appearance and Theming #
#========================#

# Black & white theme: 
#  pure black/white for focus, 
#  dark grey for tabs, 
#  grey text for inactivity & 
#  deep red (#900000) for urgency.

# Colors for Borders And Tabs
set $black          #000000
set $white          #ffffff

# Color is for Unfocused & Inactive window
set $near_black     #000001

# Color for Urgent Windows
set $red            #900000

# Colors for Unfocused Tab Title (background and text)
set $grey_bg        #272727
set $grey_text      #909090

# Apply Colors to Sway Windows
# Format: client.[state] [border] [background] [text] [indicator] [child_border]

client.focused           $near_black $black $white $white $white

client.unfocused         $black $grey_bg $grey_text $red $near_black

client.focused_inactive  $black $grey_bg $grey_text $black $near_black

client.focused_tab_title $white $black $white $grey_bg $white

#==========================#
# Additional Customisation #
#==========================#

# window customisations
default_border pixel 1
for_window [floating] border pixel 1
for_window [class="discord"] border pixel 1
for_window [window_role="GtkFileChooserDialog"] floating disable

# titlebar font size
font pango:'IBM Plex Mono' 12

# gaps please
gaps outer 5

#================#
# i3 Adjustments #
#================#

# let autorandr handle the display
exec_always autorandr --change

# Focus follows mouse when switching with keyboard
focus_follows_mouse yes
# Remember mouse to stay focused on app
mouse_warping output
# When client becomes urgent focus on immediately
focus_on_window_activation focus
# all popup windows
popup_during_fullscreen all

#=============#
# Keybindings #
#=============#

# my applications binds
include ~/.config/i3/app-binds

# kill focused window
bindsym $mod+Shift+q kill

bindsym $mod+Shift+p exec autorandr --cycle

bindsym $mod+backslash exec toggle-mic

bindsym $mod+w [title="Cisco Packet Tracer"] focus

# Reload Pipewire for audio fix
bindsym CTRL+grave exec systemctl --user restart pipewire && notify-send "Pipewire" "Reloaded"

# Use Mouse+$mod to drag floating windows to their wanted position
floating_modifier $mod

# move tiling windows via drag & drop by left-clicking into the title bar,
# or left-clicking anywhere into the window while holding the floating modifier.
tiling_drag modifier titlebar

#---------------#
# Moving Around #
#---------------#

# Left handed focus switching
bindsym $mod+Tab exec focus right
bindsym $mod+Shift+Tab exec focus left
bindsym mod1+Tab exec focus down
bindsym mod1+Shift+Tab exec focus up

# Changing Focus with vim keys
bindsym $mod+$left exec focus left
bindsym $mod+$down exec focus down
bindsym $mod+$up exec focus up
bindsym $mod+$right exec focus right

# alternatively, you can use the cursor keys:
bindsym $mod+Left exec focus left
bindsym $mod+Down exec focus down
bindsym $mod+Up exec focus up
bindsym $mod+Right exec focus right

# move focused window
bindsym $mod+Shift+$left exec move left
bindsym $mod+Shift+$down exec move down
bindsym $mod+Shift+$up exec move up
bindsym $mod+Shift+$right exec move right

# alternatively, you can use the cursor keys:
bindsym $mod+Shift+Left exec move left
bindsym $mod+Shift+Down exec move down
bindsym $mod+Shift+Up exec move up
bindsym $mod+Shift+Right exec move right

#-------------------#
# Adjusting Clients #
#-------------------#

# split in horizontal orientation
bindsym $mod+i split v

# split in vertical orientation
bindsym $mod+o split h

# enter fullscreen mode for the focused container
bindsym $mod+f fullscreen toggle

# change container layout (stacked, tabbed, toggle split)
bindsym $mod+s layout stacking
bindsym $mod+d layout tabbed
bindsym $mod+e layout toggle split

# toggle tiling / floating
bindsym $mod+Shift+space floating toggle

# change focus between tiling / floating windows
bindsym $mod+space focus mode_toggle

# focus the parent container
bindsym $mod+a focus parent

# resize window (you can also use the mouse for that)
mode "resize" {
        # These bindings trigger as soon as you enter the resize mode

        # Pressing left will shrink the window’s width.
        # Pressing right will grow the window’s width.
        # Pressing up will shrink the window’s height.
        # Pressing down will grow the window’s height.
        bindsym $left resize shrink width 10 px 
        bindsym $down resize grow height 10 px 
        bindsym $up resize shrink height 10 px 
        bindsym $right resize grow width 10 px

        # same bindings, but for the arrow keys
        bindsym Left resize shrink width 10 px 
        bindsym Down resize grow height 10 px
        bindsym Up resize shrink height 10 px
        bindsym Right resize grow width 10 px

        # back to normal: Enter or Escape or $mod+r
        bindsym Return mode "default"
        bindsym Escape mode "default"
        bindsym $mod+r mode "default"
}

bindsym $mod+r mode "resize"

#---------------------#
# Managing Workspaces #
#---------------------#

# Define names for default workspaces for which we configure key bindings later on.
# We use variables to avoid repeating the names in multiple places.
set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"
set $ws7 "7"
set $ws8 "8"
set $ws9 "9"
set $ws10 "10"

# switch to workspace
bindsym $mod+1 workspace number $ws1
bindsym $mod+2 workspace number $ws2
bindsym $mod+3 workspace number $ws3
bindsym $mod+4 workspace number $ws4
bindsym $mod+5 workspace number $ws5
bindsym $mod+6 workspace number $ws6
bindsym $mod+7 workspace number $ws7
bindsym $mod+8 workspace number $ws8
bindsym $mod+9 workspace number $ws9
bindsym $mod+0 workspace number $ws10

# send container to workspace
bindsym Mod1+1 move container to workspace number $ws1
bindsym Mod1+2 move container to workspace number $ws2
bindsym Mod1+3 move container to workspace number $ws3
bindsym Mod1+4 move container to workspace number $ws4
bindsym Mod1+5 move container to workspace number $ws5
bindsym Mod1+6 move container to workspace number $ws6
bindsym Mod1+7 move container to workspace number $ws7
bindsym Mod1+8 move container to workspace number $ws8
bindsym Mod1+9 move container to workspace number $ws9
bindsym Mod1+0 move container to workspace number $ws10

# move focused container along workspaces
bindsym $mod+Shift+1 move container to workspace number $ws1; workspace number $ws1
bindsym $mod+Shift+2 move container to workspace number $ws2; workspace number $ws2
bindsym $mod+Shift+3 move container to workspace number $ws3; workspace number $ws3
bindsym $mod+Shift+4 move container to workspace number $ws4; workspace number $ws4
bindsym $mod+Shift+5 move container to workspace number $ws5; workspace number $ws5
bindsym $mod+Shift+6 move container to workspace number $ws6; workspace number $ws6
bindsym $mod+Shift+7 move container to workspace number $ws7; workspace number $ws7
bindsym $mod+Shift+8 move container to workspace number $ws8; workspace number $ws8
bindsym $mod+Shift+9 move container to workspace number $ws9; workspace number $ws9
bindsym $mod+Shift+0 move container to workspace number $ws10; workspace number $ws10

#------------------#
# Utility Keybinds #
#------------------#

# reload the configuration file
bindsym $mod+Shift+c reload
# restart i3 inplace (preserves your layout/session, can be used to upgrade i3)
bindsym $mod+Shift+r restart

# Use pactl to adjust volume in PulseAudio.
bindsym XF86AudioRaiseVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ +1%
bindsym XF86AudioLowerVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ -1%
bindsym XF86AudioMute exec --no-startup-id pactl set-sink-mute @DEFAULT_SINK@ toggle
bindsym XF86AudioMicMute exec --no-startup-id pactl set-source-mute @DEFAULT_SOURCE@ toggle
# Special Keys to adjust the brightness
bindsym XF86MonBrightnessUp exec --no-startup-id brightnessctl set 10%+
bindsym XF86MonBrightnessDown exec --no-startup-id brightnessctl set 10%-

#------------#
# Status Bar #
#------------#

# Start i3bar to display a workspace bar (plus the system information i3status
# finds out, if available)
bar {
	position top
	font pango:monospace 13

        status_command i3status-rs
	tray_output primary
	colors {
		inactive_workspace #000000 #000000 #FFFFFF
		focused_workspace  #FFFFFF #000000 #FFFFFF
	}
}
