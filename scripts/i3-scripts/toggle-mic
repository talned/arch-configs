#!/usr/bin/env bash

NOTIFY_ID_FILE="${XDG_RUNTIME_DIR:-/tmp}/mic_notify_id"

notify_mic() {
    # $1 = "Muted" or "Unmuted"
    # $2 = notification id (if any)
    if [ -n "$2" ]; then
        new_id=$(notify-send "Microphone" "Mic $1" --replace-id="$2" -p)
    else
        new_id=$(notify-send "Microphone" "Mic $1" -p)
    fi
    echo "$new_id" > "$NOTIFY_ID_FILE"
}

current_id=""
[ -f "$NOTIFY_ID_FILE" ] && current_id=$(cat "$NOTIFY_ID_FILE")

# Toggle once
pactl set-source-mute @DEFAULT_SOURCE@ toggle

# Check new state and notify
is_muted_after=$(pactl get-source-mute @DEFAULT_SOURCE@ | awk '{print $2}')
if [ "$is_muted_after" = "yes" ]; then
    notify_mic "Muted" "$current_id"
else
    notify_mic "Unmuted" "$current_id"
fi

pkill -SIGRTMIN+10 i3status-rs 2>/dev/null || true

